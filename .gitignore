<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="#07090a">
    <title>Mohammed Siddique | CALEX International</title>
    <meta
      name="description"
      content="Digital business card for Mohammed Siddique, Business Development Executive at CALEX International."
    >
    <link rel="stylesheet" href="styles.css">
  </head>
  <body>
    <main class="card-shell" aria-label="Digital business card">
      <section class="brand-panel" aria-labelledby="person-name">
        <div class="portrait-wrap">
          <img
            class="portrait"
            src="assets/profile.png"
            alt="Mohammed Siddique"
            width="520"
            height="520"
          >
        </div>

        <div class="identity">
          <p class="eyebrow">CALEX International</p>
          <h1 id="person-name">Mohammed<br>Siddique</h1>
          <div class="gold-rule" aria-hidden="true"><span></span></div>
          <p class="role">Business Development Executive</p>
        </div>

        <address class="contact-list">
          <a class="contact-row" href="tel:+966543949292">
            <span class="icon" aria-hidden="true">
              <svg viewBox="0 0 24 24"><path d="M22 16.92v2.4a2.1 2.1 0 0 1-2.29 2.1A20.55 20.55 0 0 1 3.03 4.73 2.1 2.1 0 0 1 5.12 2.5h2.4a2.1 2.1 0 0 1 2.08 1.8l.36 2.54a2.1 2.1 0 0 1-.6 1.82L8.2 9.84a15.4 15.4 0 0 0 5.96 5.96l1.18-1.16a2.1 2.1 0 0 1 1.82-.6l2.54.36A2.1 2.1 0 0 1 22 16.92Z"/></svg>
            </span>
            <span><strong>054 394 9292</strong><small>Mobile</small></span>
          </a>
          <a class="contact-row" href="mailto:sales1@calexint.com">
            <span class="icon" aria-hidden="true">
              <svg viewBox="0 0 24 24"><path d="M3.5 6.5h17v11h-17z"/><path d="m4 7 8 6 8-6"/></svg>
            </span>
            <span><strong>Sales1@calexint.com</strong><small>Email</small></span>
          </a>
          <a class="contact-row" href="https://www.calexint.com" target="_blank" rel="noopener">
            <span class="icon" aria-hidden="true">
              <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3c2.7 2.7 4 5.7 4 9s-1.3 6.3-4 9c-2.7-2.7-4-5.7-4-9s1.3-6.3 4-9Z"/></svg>
            </span>
            <span><strong>www.calexint.com</strong><small>Website</small></span>
          </a>
          <p class="contact-row">
            <span class="icon" aria-hidden="true">
              <svg viewBox="0 0 24 24"><path d="M12 21s7-6.6 7-12a7 7 0 0 0-14 0c0 5.4 7 12 7 12Z"/><circle cx="12" cy="9" r="2.6"/></svg>
            </span>
            <span><strong>Kingdom of Saudi Arabia</strong><small>Based in KSA</small></span>
          </p>
        </address>

        <div class="quick-contact" aria-label="Quick contact actions">
          <div class="section-title"><span></span>Quick Contact<span></span></div>
          <div class="quick-grid">
            <a class="quick-button" href="tel:+966543949292">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M22 16.92v2.4a2.1 2.1 0 0 1-2.29 2.1A20.55 20.55 0 0 1 3.03 4.73 2.1 2.1 0 0 1 5.12 2.5h2.4a2.1 2.1 0 0 1 2.08 1.8l.36 2.54a2.1 2.1 0 0 1-.6 1.82L8.2 9.84a15.4 15.4 0 0 0 5.96 5.96l1.18-1.16a2.1 2.1 0 0 1 1.82-.6l2.54.36A2.1 2.1 0 0 1 22 16.92Z"/></svg>
              Call Me
            </a>
            <a class="quick-button" href="https://wa.me/966543949292" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4.4 19.6 5.6 16A8 8 0 1 1 8 18.4l-3.6 1.2Z"/><path d="M9 8.8c.3 2.3 1.9 4.1 4.2 4.9l1.5-1.1 2.1 1.1c-.3 1.4-1.4 2.3-2.8 2.3-3.7 0-7-3.3-7-7 0-1.4.9-2.5 2.3-2.8l1.1 2.1L9 8.8Z"/></svg>
              WhatsApp Me
            </a>
            <a class="quick-button" href="mailto:sales1@calexint.com">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3.5 6.5h17v11h-17z"/><path d="m4 7 8 6 8-6"/></svg>
              Send Email
            </a>
            <a class="quick-button" href="https://www.linkedin.com/" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 9h4v11H4zM4 4h4v3H4zM11 9h3.8v1.6c.6-1 1.7-1.9 3.5-1.9 2.5 0 4 1.7 4 5V20h-4v-5.7c0-1.4-.6-2.1-1.7-2.1-1.2 0-1.8.8-1.8 2.1V20H11z"/></svg>
              Connect on LinkedIn
            </a>
            <a class="quick-button" href="https://www.calexint.com" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3c2.7 2.7 4 5.7 4 9s-1.3 6.3-4 9c-2.7-2.7-4-5.7-4-9s1.3-6.3 4-9Z"/></svg>
              Visit Website
            </a>
            <a class="quick-button" href="mailto:sales1@calexint.com?subject=Request%20for%20Quotation%20-%20CALEX%20International">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 2.8h9l4 4V21H6z"/><path d="M15 3v4h4M9 11h6M9 15h6"/></svg>
              Request Quotation
            </a>
          </div>
        </div>
      </section>

      <section class="solutions-panel" aria-labelledby="brand-name">
        <div class="map-dots" aria-hidden="true"></div>
        <div class="brand-mark">
          <h2 id="brand-name"><span>C</span><span class="logo-a">A</span><span>LEX</span></h2>
          <p>International</p>
        </div>
        <p class="tagline">Building Connections.<br>Delivering <strong>Excellence.</strong></p>
        <div class="star-line" aria-hidden="true"><span></span></div>

        <div class="solutions-card">
          <h3>
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 6V4h6v2M4 8h16v11H4zM4 12h16M10 12v2h4v-2"/></svg>
            Our Solutions
          </h3>
          <ul>
            <li>Manpower Supply</li>
            <li>Offshore Personnel Mobilization</li>
            <li>Industrial Equipment &amp; Tools</li>
            <li>Procurement Solutions</li>
            <li>Project Support Services</li>
          </ul>
        </div>

        <div class="qr-card" aria-label="Scan to save contact">
          <div class="qr-frame">
            <img src="assets/contact-qr.svg" alt="QR code to save Mohammed Siddique contact">
            <div class="qr-logo" aria-hidden="true">A</div>
          </div>
          <a class="tap-button" href="mohammed-siddique.vcf" download>
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M8 3h8v18H8z"/><path d="M10 6h4M10 18h4"/><path d="M18 8c1.4.7 2.4 2.2 2.4 4s-1 3.3-2.4 4M6 8c-1.4.7-2.4 2.2-2.4 4S4.6 15.3 6 16"/></svg>
            <span><strong>Tap or Scan</strong><small>to save my contact</small></span>
          </a>
        </div>
      </section>

      <section class="service-strip" aria-label="Service focus areas">
        <article class="service-card industrial">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 20V9l4 3V9l4 3V5h4v7l4-3v11z"/><path d="M7 16h2M11 16h2M15 16h2"/></svg>
          <h3>Industrial<br>Solutions</h3>
        </article>
        <article class="service-card marine">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 15h14l-2 4H7zM8 15V9h8v6M10 9V5h4v4"/><path d="M4 20c1.5 1 3 1 4.5 0s3-1 4.5 0 3 1 4.5 0 3-1 4.5 0"/></svg>
          <h3>Marine<br>Services</h3>
        </article>
        <article class="service-card global">
          <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3c2.7 2.7 4 5.7 4 9s-1.3 6.3-4 9c-2.7-2.7-4-5.7-4-9s1.3-6.3 4-9Z"/></svg>
          <h3>Global<br>Standards</h3>
        </article>
        <article class="service-card vision">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 17c4-3 12-3 16 0M6 20h12M12 4v11M8 7h8"/><path d="M7 9c1.5 1 3.5 1 5 0s3.5-1 5 0"/></svg>
          <h3>Saudi<br>Vision</h3>
        </article>
      </section>
    </main>
  </body>
</html>

